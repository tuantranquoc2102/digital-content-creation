# Application
APP_NAME="Digital Content Creation API"
APP_VERSION="1.0.0"
DEBUG=false

# Audio
AUDIO_OUTPUT_DIR=temp/audio
MAX_AUDIO_DURATION_SECONDS=3600

# Video
VIDEO_OUTPUT_DIR=temp/video
VIDEO_FONTS_DIR=static/fonts
VIDEO_DEFAULT_FONT_FILENAME=UVNMangCau_B.ttf

# TTS (Text to Speech)
TTS_OUTPUT_DIR=temp/tts
# Set to false to open a visible browser window during TTS (useful for debugging)
TTS_HEADLESS=true
# Max characters per TTS request chunk (Zalo TTS only reads the first line per submit)
TTS_CHUNK_SIZE=500

# Whisper transcription
# Options: tiny | base | small | medium | large
WHISPER_MODEL=base
# Options: cpu | cuda
WHISPER_DEVICE=cpu
